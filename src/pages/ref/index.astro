---
import Base from "../../layouts/Base.astro";

const pieces = [
  { slug: "pd-00-infrastructure-hits", title: "The Physical Toll", num: "00", desc: "Naming the wreckage — 40+ energy assets damaged across 9 countries, repair timelines measured in years.", category: "Reference" },
  { slug: "pd-01-guarantor", title: "The Guarantor Became the Source", num: "01", desc: "The petrodollar was a security arrangement disguised as a market. When the guarantor struck the system it guaranteed, the system broke.", category: "The Paradox" },
  { slug: "pd-02-vault-drain", title: "The Vault Drain", num: "02", desc: "The paper market and the physical market have decoupled. Central banks are demanding metal, not promises.", category: "The Evidence" },
  { slug: "pd-03-yuan-strait", title: "Yuan at the Strait", num: "03", desc: "Fifteen years of plumbing — built for one purpose, repurposed for another — cleared its first transaction at the world's most important chokepoint.", category: "The Mechanism" },
  { slug: "pd-04-hierarchy", title: "The Hierarchy Breaks From the Bottom", num: "04", desc: "The dollar is still dominant. The hierarchy it sits on is fracturing — at the base, not the top.", category: "The Framework" },
  { slug: "pd-05-who-pays", title: "Who Pays", num: "05", desc: "The architects debate frameworks. The last link eats less. Every monetary transition redistributes costs downward.", category: "The Cost" },
  { slug: "pd-06-petrodollar-2", title: "Petrodollar 2.0", num: "06", desc: "Not a treaty. Not a military guarantee. Private digital dollars that create Treasury demand through market adoption.", category: "The Counter-Move" },
  { slug: "pd-07-australias-moment", title: "Australia's Moment", num: "07", desc: "The petrodollar break creates an asymmetric opportunity for Australia. AUKUS constrains Australia's ability to capitalize.", category: "The Signal" },
];

// JSON-LD: WebPage
const webpageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "The Petrodollar Series — Reference",
  "description": "A structural analysis of what's breaking in the global monetary system.",
  "url": Astro.url.toString(),
  "isPartOf": {
    "@type": "WebSite",
    "name": "The Agentic Economy",
    "url": new URL("/", Astro.site).toString()
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL("/", Astro.site).toString() },
      { "@type": "ListItem", "position": 2, "name": "Reference", "item": Astro.url.toString() }
    ]
  }
};
---
<Base title="The Petrodollar Series — Reference">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webpageJsonLd)} />
  </Fragment>
  <div class="ref-index">
    <header class="ref-index-header">
      <span class="ref-index-label">Reference Series</span>
      <h1 class="ref-index-title">The Fracturing of the Petrodollar</h1>
      <p class="ref-index-subtitle">An eight-part structural analysis of what's breaking in the global monetary system, what replaces it, and who pays.</p>
    </header>

    <div class="ref-index-grid">
      {pieces.map((piece) => (
        <a class="ref-card" href={`/ref/${piece.slug}`}>
          <div class="ref-card-meta">
            <span class="ref-card-num">{piece.num}</span>
            <span class="ref-card-category">{piece.category}</span>
          </div>
          <h2 class="ref-card-title">{piece.title}</h2>
          <p class="ref-card-desc">{piece.desc}</p>
          <span class="ref-card-link">Read →</span>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .ref-index {
    max-width: var(--col-read);
    margin: 0 auto;
    padding: var(--space-4xl) var(--space-xl) var(--space-3xl);
  }
  .ref-index-header {
    margin-bottom: var(--space-3xl);
  }
  .ref-index-label {
    display: inline-block;
    font-family: var(--ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-md);
  }
  .ref-index-title {
    font-family: var(--display);
    font-size: clamp(2rem, 5vw, 2.5rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--text);
    margin: 0 0 var(--space-md);
  }
  .ref-index-subtitle {
    font-family: var(--body);
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 40rem;
  }
  .ref-index-grid {
    display: flex;
    flex-direction: column;
  }
  .ref-card {
    display: block;
    text-decoration: none;
    color: var(--text);
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--border);
    transition: opacity 100ms ease-out;
  }
  .ref-card:first-child {
    border-top: 1px solid var(--border);
  }
  .ref-card:hover {
    opacity: 0.85;
  }
  .ref-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }
  .ref-card-num {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--subtle);
  }
  .ref-card-category {
    font-family: var(--ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .ref-card-title {
    font-family: var(--display);
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-sm);
    color: var(--text);
    transition: color 100ms ease-out;
  }
  .ref-card:hover .ref-card-title {
    color: var(--accent);
  }
  .ref-card-desc {
    font-family: var(--body);
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    max-width: 40rem;
  }
  .ref-card-link {
    font-family: var(--ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    transition: transform 150ms ease-out;
    display: inline-block;
    margin-top: var(--space-sm);
  }
  .ref-card:hover .ref-card-link {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .ref-index {
      padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
    }
    .ref-index-header {
      margin-bottom: var(--space-2xl);
    }
    .ref-card {
      padding: var(--space-lg) 0;
    }
  }

  @media (max-width: 640px) {
    .ref-index {
      padding: var(--space-2xl) var(--space-md) var(--space-xl);
    }
    .ref-index-title {
      font-size: 1.75rem;
    }
    .ref-card-meta {
      flex-wrap: wrap;
    }
  }
</style>
