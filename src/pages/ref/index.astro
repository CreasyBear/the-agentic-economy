---
import Base from "../../layouts/Base.astro";

const pieces = [
  { slug: "pd-00-infrastructure-hits", title: "The Physical Toll", num: "00", desc: "Naming the wreckage — 40+ energy assets damaged across 9 countries, repair timelines measured in years.", category: "Reference" },
  { slug: "pd-01-guarantor", title: "The Guarantor Became the Source", num: "01", desc: "The petrodollar was a security arrangement disguised as a market. When the guarantor struck the system it guaranteed, the system broke.", category: "The Paradox" },
  { slug: "pd-02-vault-drain", title: "The Vault Drain", num: "02", desc: "The paper market and the physical market have decoupled. Central banks are demanding metal, not promises.", category: "The Evidence" },
  { slug: "pd-03-yuan-strait", title: "Yuan at the Strait", num: "03", desc: "Fifteen years of plumbing — built for one purpose, repurposed for another — cleared its first transaction at the world's most important chokepoint.", category: "The Mechanism" },
  { slug: "pd-04-hierarchy", title: "The Hierarchy Breaks From the Bottom", num: "04", desc: "The dollar is still dominant. The hierarchy it sits on is fracturing — at the base, not the top.", category: "The Framework" },
  { slug: "pd-05-who-pays", title: "Who Pays", num: "05", desc: "The architects debate frameworks. The last link eats less. Every monetary transition redistributes costs downward.", category: "The Cost" },
  { slug: "pd-06-petrodollar-2", title: "Petrodollar 2.0", num: "06", desc: "Not a treaty. Not a military guarantee. Private digital dollars that create Treasury demand through market adoption.", category: "The Counter-Move" },
];
---
<Base title="The Petrodollar Series — Reference">
  <div class="ref-index">
    <header class="ref-index-header">
      <span class="ref-index-label">Reference Series</span>
      <h1 class="ref-index-title">The Fracturing of the Petrodollar</h1>
      <p class="ref-index-subtitle">A six-part structural analysis of what's breaking in the global monetary system, what replaces it, and who pays.</p>
    </header>

    <div class="ref-index-grid">
      {pieces.map((piece) => (
        <a class="ref-card" href={`/ref/${piece.slug}`}>
          <div class="ref-card-meta">
            <span class="ref-card-num">{piece.num}</span>
            <span class="ref-card-category">{piece.category}</span>
          </div>
          <h2 class="ref-card-title">{piece.title}</h2>
          <p class="ref-card-desc">{piece.desc}</p>
          <span class="ref-card-link">Read →</span>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .ref-index {
    max-width: 52rem;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
  }
  .ref-index-header {
    margin-bottom: 3rem;
  }
  .ref-index-label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent, #c4842d);
    margin-bottom: 0.75rem;
  }
  .ref-index-title {
    font-family: var(--font-heading, "Fraunces", serif);
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-heading, #fafafa);
    margin-bottom: 1rem;
  }
  .ref-index-subtitle {
    font-size: 1.1rem;
    color: var(--color-muted, #a1a1aa);
    line-height: 1.6;
    max-width: 40rem;
  }
  .ref-index-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .ref-card {
    display: block;
    text-decoration: none;
    color: var(--color-text, #e4e4e7);
    padding: 2rem 0;
    border-top: 1px solid var(--color-border, #27272a);
    transition: all 0.2s;
  }
  .ref-card:last-child {
    border-bottom: 1px solid var(--color-border, #27272a);
  }
  .ref-card:hover {
    color: var(--color-heading, #fafafa);
  }
  .ref-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .ref-card-num {
    font-family: var(--font-mono, "JetBrains Mono", monospace);
    font-size: 0.8rem;
    color: var(--color-muted, #a1a1aa);
  }
  .ref-card-category {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent, #c4842d);
  }
  .ref-card-title {
    font-family: var(--font-body, "Inter", sans-serif);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    color: inherit;
  }
  .ref-card-desc {
    font-size: 0.95rem;
    color: var(--color-muted, #a1a1aa);
    line-height: 1.6;
    margin-bottom: 0.75rem;
    max-width: 40rem;
  }
  .ref-card-link {
    font-size: 0.85rem;
    color: var(--color-accent, #c4842d);
    font-weight: 500;
    transition: transform 0.15s;
    display: inline-block;
  }
  .ref-card:hover .ref-card-link {
    transform: translateX(4px);
  }
</style>
