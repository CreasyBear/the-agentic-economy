---
import Essay from "../../layouts/Essay.astro";
import * as pd_01_guarantor from "../../../ref/pd-01-guarantor.mdx";
const Content = pd_01_guarantor.default;
---
<Essay
    title="The Guarantor Became the Source"
    eyebrow="Reference · Petrodollar Series"
    description="The paradox of the guarantor striking its own system"
    prev={{ slug: "ref/pd-00-infrastructure-hits", title: "The Physical Toll" }}
    next={{ slug: "ref/pd-02-vault-drain", title: "The Vault Drain" }}
