    :global(.agentic-payload) { display: none !important; }
  }
  /* Tighten prose for reading */
  :global(.essay-prose h2) { margin-top: 3rem; }
  :global(.essay-prose blockquote) { font-size: 1.1rem; }
</style>
</Essay>
