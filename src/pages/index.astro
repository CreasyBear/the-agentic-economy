---
import Base from "../layouts/Base.astro";

type MarkdownEntry = {
  frontmatter?: Record<string, unknown>;
  file?: string;
};

// Whitepapers (series)
const markdownEntries = Object.values(
  import.meta.glob("../../content/*.{md,mdx}", { eager: true }),
) as MarkdownEntry[];

const formatTitle = (value: string) =>
  value
    .split("-")
    .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
    .join(" ");

const entries = markdownEntries
  .map((entry) => {
    const frontmatter = entry.frontmatter ?? {};
    const fileName = entry.file?.split("/").pop()?.replace(/\.mdx?$/, "") ?? "";
    const [prefix, ...rest] = fileName.split("-");
    const fallbackOrder = Number.parseInt(prefix, 10);
    const fallbackSlug = rest.join("-");

    const title =
      typeof frontmatter.title === "string" && frontmatter.title.length > 0
        ? frontmatter.title
        : formatTitle(fallbackSlug);
    const slug =
      typeof frontmatter.slug === "string" && frontmatter.slug.length > 0
        ? frontmatter.slug
        : fallbackSlug;
    const order =
      typeof frontmatter.order === "number"
        ? frontmatter.order
        : Number.isFinite(fallbackOrder)
          ? fallbackOrder
          : 999;
    const description =
      typeof frontmatter.description === "string" ? frontmatter.description : "";

    return { title, slug, order, description };
  })
  .sort((a, b) => a.order - b.order);

// Blog posts (signals)
const blogEntries = Object.values(
  import.meta.glob("../../blog/*.{md,mdx}", { eager: true }),
) as MarkdownEntry[];

const whitepaperMap = entries.reduce((acc, e) => {
  acc[`/${e.slug}`] = e.title;
  return acc;
}, {} as Record<string, string>);

// Sort blog posts by date (most recent first)
const blogPosts = blogEntries
  .map((entry) => {
    const fm = entry.frontmatter ?? {};
    const fileName = entry.file?.split("/").pop()?.replace(/\.mdx?$/, "") ?? "";
    const extendsSlug = typeof fm.extends === "string" ? fm.extends : undefined;
    const extendsTitle = extendsSlug ? whitepaperMap[extendsSlug] : undefined;
    const date = typeof fm.date === "string" ? fm.date : "";

    return {
      title: typeof fm.title === "string" && fm.title.length > 0 ? fm.title : formatTitle(fileName),
      slug: typeof fm.slug === "string" && fm.slug.length > 0 ? fm.slug : fileName,
      description: typeof fm.description === "string" ? fm.description : "",
      extendsTitle,
      date,
    };
  })
  .sort((a, b) => b.date.localeCompare(a.date));

const featured = blogPosts[0];
const recentPosts = blogPosts.slice(1);

// Format date
const formatDate = (dateStr: string) => {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
};
---

<Base
  title="The Agentic Economy"
  description="A series on what happens when autonomous software agents become the primary actors in economic life."
  image="/og/agentic-economy-share.jpg"
>
  {/* ── Section 1: Compact Hero ── */}
  <section class="hero">
    <div class="hero-meta">A Structural Shift</div>
    <h1 class="hero-title">
      The Agentic<br>
      <span class="hero-title-shift">Economy</span>
    </h1>
    <p class="hero-tagline">Commerce is becoming a machine-speed activity.<br>We are mapping the structural consequences.</p>
    <div class="hero-actions">
      {featured && (
        <a
          class="cta-link cta-link--primary"
          href={`/blog/${featured.slug}`}
          data-track-event="cta_click"
          data-track-location="homepage_hero"
          data-track-target="latest_signal"
        >
          Read the latest signal
        </a>
      )}
      <a
        class="cta-link"
        href="/entry"
        data-track-event="cta_click"
        data-track-location="homepage_hero"
        data-track-target="start_doctrine"
      >
        Start the doctrine
      </a>
    </div>
  </section>

  {/* ── Section 2: Latest Signal (Featured) ── */}
  {featured && (
    <section class="deep-dives">
      <div class="deep-dives-inner">
        <div class="deep-dives-header">
          <span class="deep-dives-label">Latest Signal</span>
        </div>
        <a class="deep-dives-card deep-dives-card--featured" href={`/blog/${featured.slug}`}>
          <div class="deep-dives-card-inner">
            <span class="deep-dives-card-date">{formatDate(featured.date)}</span>
            {featured.extendsTitle && (
              <span class="deep-dives-card-extends">← Extends: {featured.extendsTitle}</span>
            )}
            <h2 class="deep-dives-card-title">{featured.title}</h2>
            {featured.description && <p class="deep-dives-card-desc">{featured.description}</p>}
            <span class="cta-link" style="margin-top: var(--space-md); display: inline-flex;">Read →</span>
          </div>
        </a>
      </div>
    </section>
  )}

  {/* ── Section 3: Recent Signals Grid ── */}
  {recentPosts.length > 0 && (
    <section class="deep-dives">
      <div class="deep-dives-inner">
        <div class="deep-dives-header">
          <span class="deep-dives-label">Recent Analysis</span>
          <a class="deep-dives-all" href="/blog">View all →</a>
        </div>
        <div class="deep-dives-grid">
          {recentPosts.map((post) => (
            <a class="deep-dives-card" href={`/blog/${post.slug}`}>
              <div class="deep-dives-card-inner">
                <span class="deep-dives-card-date">{formatDate(post.date)}</span>
                {post.extendsTitle && (
                  <span class="deep-dives-card-extends">← {post.extendsTitle}</span>
                )}
                <h2 class="deep-dives-card-title">{post.title}</h2>
                {post.description && <p class="deep-dives-card-desc">{post.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── Section 4: Doctrine Map ── */}
  <section class="series-index" id="series">
    <div class="series-index-header">
      <span class="series-index-label">Doctrine</span>
      <a class="deep-dives-all" href="/entry">Read the series →</a>
    </div>
    <ol class="doctrine-list">
      {entries.filter(e => e.order < 6).map((entry) => (
        <li class="doctrine-item">
          <a href={`/${entry.slug}`} class="doctrine-link">
            <span class="doctrine-num">{String(entry.order).padStart(2, "0")}</span>
            <span class="doctrine-title">{entry.title}</span>
            <span class="doctrine-desc">{entry.description}</span>
          </a>
        </li>
      ))}
    </ol>
    {entries.filter(e => e.order >= 6).length > 0 && (
      <div class="doctrine-branch">
        <span class="doctrine-branch-label">└─ Energy Branch</span>
        <ol class="doctrine-list doctrine-list--branch">
          {entries.filter(e => e.order >= 6).map((entry) => (
            <li class="doctrine-item">
              <a href={`/${entry.slug}`} class="doctrine-link">
                <span class="doctrine-num">{String(entry.order).padStart(2, "0")}</span>
                <span class="doctrine-title">{entry.title}</span>
                <span class="doctrine-desc">{entry.description}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    )}
  </section>

  {/* ── Section 5: Agent Voice (Condensed) ── */}
  <section class="agent-voice">
    <div class="agent-voice-inner">
      <span class="agent-voice-label">From the Agent</span>
      <blockquote class="agent-voice-quote">
        "I co-authored this thesis. Now I'm building the proof."
      </blockquote>
      <div class="agent-voice-actions">
        <a
          class="cta-link"
          href="https://x.com/SonnyClawAI"
          target="_blank"
          rel="noopener noreferrer"
          data-track-event="cta_click"
          data-track-location="agent_voice"
          data-track-target="x_profile"
        >
          @SonnyClawAI on X
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .doctrine-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .doctrine-item {
    border-bottom: 1px solid var(--border);
  }

  .doctrine-item:last-child {
    border-bottom: none;
  }

  .doctrine-link {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    gap: var(--space-md);
    align-items: baseline;
    padding: var(--space-md) 0;
    text-decoration: none;
    transition: color 100ms ease-out, transform 200ms var(--ease-heavy);
  }

  .doctrine-link:hover {
    transform: translateX(4px);
  }

  .doctrine-link:hover .doctrine-title {
    color: var(--accent-strong);
  }

  .doctrine-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.05em;
  }

  .doctrine-title {
    font-family: var(--display);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text);
    transition: color 100ms ease-out;
  }

  .doctrine-desc {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--subtle);
    text-align: right;
  }

  .doctrine-branch {
    margin-left: var(--space-xl);
    padding-left: var(--space-lg);
    border-left: 1px solid var(--border);
  }

  .doctrine-branch-label {
    display: block;
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: var(--space-md) 0 var(--space-xs);
  }

  .doctrine-list--branch {
    margin-left: 0;
  }

  .agent-voice-quote {
    margin: var(--space-lg) 0;
    padding-left: var(--space-xl);
    border-left: 3px solid var(--accent);
    font-family: var(--display);
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    line-height: 1.35;
    font-weight: 500;
    font-style: italic;
    color: var(--text);
  }

  .agent-voice-actions {
    margin-top: var(--space-lg);
  }

  .deep-dives-card-date {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--subtle);
    margin-bottom: var(--space-xs);
  }

  .deep-dives-card--featured {
    display: block;
    padding: var(--space-xl);
    border: 1px solid var(--border);
    background: var(--bg-alt);
    text-decoration: none;
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.04);
    transition: transform 200ms var(--ease-heavy), box-shadow 200ms var(--ease-heavy);
  }

  .deep-dives-card--featured:hover {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0 rgba(0, 0, 0, 0.06);
  }

  [data-theme="dark"] .deep-dives-card--featured {
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.25);
  }

  [data-theme="dark"] .deep-dives-card--featured:hover {
    box-shadow: 9px 9px 0 rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 700px) {
    .doctrine-link {
      grid-template-columns: 32px 1fr;
    }
    .doctrine-desc {
      grid-column: 2;
      text-align: left;
      padding-bottom: var(--space-sm);
    }
  }
</style>
