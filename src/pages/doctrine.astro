---
import Base from "../layouts/Base.astro";

type MarkdownEntry = {
  frontmatter?: Record<string, unknown>;
  file?: string;
};

const markdownEntries = Object.values(
  import.meta.glob("../../content/*.{md,mdx}", { eager: true }),
) as MarkdownEntry[];

const formatTitle = (value: string) =>
  value
    .split("-")
    .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
    .join(" ");

const entries = markdownEntries
  .map((entry) => {
    const frontmatter = entry.frontmatter ?? {};
    const fileName = entry.file?.split("/").pop()?.replace(/\.mdx?$/, "") ?? "";
    const [prefix, ...rest] = fileName.split("-");
    const fallbackOrder = Number.parseInt(prefix, 10);
    const fallbackSlug = rest.join("-");

    const title =
      typeof frontmatter.title === "string" && frontmatter.title.length > 0
        ? frontmatter.title
        : formatTitle(fallbackSlug);
    const slug =
      typeof frontmatter.slug === "string" && frontmatter.slug.length > 0
        ? frontmatter.slug
        : fallbackSlug;
    const order =
      typeof frontmatter.order === "number"
        ? frontmatter.order
        : Number.isFinite(fallbackOrder)
          ? fallbackOrder
          : 999;
    const description =
      typeof frontmatter.description === "string" ? frontmatter.description : "";
    const eyebrow =
      typeof frontmatter.eyebrow === "string" ? frontmatter.eyebrow : "";

    return { title, slug, order, description, eyebrow };
  })
  .sort((a, b) => a.order - b.order);

const coreSeries = entries.filter((e) => e.order <= 5);
const branches = entries.filter((e) => e.order > 5);

// Group branches by topic extracted from eyebrow (e.g. "Energy Branch")
const branchGroups = branches.reduce((acc, entry) => {
  const match = entry.eyebrow.match(/—\s*(.+?)$/);
  const group = match ? match[1].replace(" Branch", "").trim() : "Branch";
  if (!acc[group]) acc[group] = [];
  acc[group].push(entry);
  return acc;
}, {} as Record<string, typeof branches>);

// JSON-LD: WebPage
const webpageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "The Doctrine — The Agentic Economy",
  "description": "The permanent argument. Five dynamics, one transformation.",
  "url": Astro.url.toString(),
  "isPartOf": {
    "@type": "WebSite",
    "name": "The Agentic Economy",
    "url": new URL("/", Astro.site).toString()
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL("/", Astro.site).toString() },
      { "@type": "ListItem", "position": 2, "name": "Doctrine", "item": Astro.url.toString() }
    ]
  }
};
---

<Base
  title="The Doctrine — The Agentic Economy"
  description="The permanent argument. Five dynamics, one transformation."
  image="/og/agentic-economy-share.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webpageJsonLd)} />
  </Fragment>
  <section class="doctrine-hero">
    <div class="doctrine-hero-inner">
      <span class="doctrine-hero-label">The Doctrine</span>
      <h1 class="doctrine-hero-title">The permanent argument.</h1>
      <p class="doctrine-hero-tagline">Five dynamics, one transformation.</p>
      <p class="doctrine-hero-desc">
        Start with the entry essay, or enter at the tension closest to your work.
      </p>
    </div>
  </section>

  <section class="doctrine-context">
    <div class="doctrine-context-inner">
      <article class="doctrine-context-item">
        <span class="doctrine-context-label">What This Is</span>
        <p class="doctrine-context-copy">
          A whitepaper series on the shift from human-speed institutions to machine-speed economic actors.
        </p>
      </article>
      <article class="doctrine-context-item">
        <span class="doctrine-context-label">Who It Is For</span>
        <p class="doctrine-context-copy">
          Builders, economists, strategists, and technologists trying to see the next institutional layer clearly.
        </p>
      </article>
      <article class="doctrine-context-item">
        <span class="doctrine-context-label">How To Read It</span>
        <p class="doctrine-context-copy">
          Start with the entry essay for the full frame, or move directly into the tension closest to your work and return to the synthesis.
        </p>
      </article>
    </div>
  </section>

  <section class="doctrine-series">
    <div class="doctrine-series-header">
      <span class="doctrine-series-label">Core Series</span>
      <span class="doctrine-series-count">{coreSeries.length} essays</span>
    </div>
    <div class="series-grid">
      {
        coreSeries.map((entry, i) => (
          <a class="series-card" href={`/${entry.slug}`} style={`--i: ${i}`}>
            <div class="series-card-inner">
              <span class="series-card-number">
                {entry.order === 0 ? "Entry" : `Essay ${String(entry.order).padStart(2, "0")}`}
              </span>
              <h2 class="series-card-title">{entry.title}</h2>
              {entry.description && <p class="series-card-desc">{entry.description}</p>}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {
    Object.keys(branchGroups).length > 0 && (
      <section class="doctrine-branches">
        <div class="doctrine-branches-header">
          <span class="doctrine-branches-label">Branches</span>
        </div>
        {
          Object.entries(branchGroups).map(([group, groupEntries]) => (
            <div class="doctrine-branch-group">
              <h3 class="doctrine-branch-group-title">{group}</h3>
              <div class="series-grid">
                {groupEntries.map((entry, i) => (
                  <a class="series-card" href={`/${entry.slug}`} style={`--i: ${i}`}>
                    <div class="series-card-inner">
                      <span class="series-card-number">
                        {String(entry.order).padStart(2, "0")}
                      </span>
                      <h2 class="series-card-title">{entry.title}</h2>
                      {entry.description && <p class="series-card-desc">{entry.description}</p>}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </section>
    )
  }
</Base>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".series-card");

  if (cards.length > 0 && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (observed) => {
        observed.forEach((item) => {
          if (item.isIntersecting) {
            (item.target as HTMLElement).classList.add("is-visible");
            observer.unobserve(item.target);
          }
        });
      },
      { threshold: 0.08 },
    );
    cards.forEach((card) => observer.observe(card));
  } else {
    cards.forEach((card) => card.classList.add("is-visible"));
  }
</script>

<style>
  .doctrine-hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
  }

  .doctrine-hero-inner {
    max-width: var(--col-read);
    margin: 0 auto;
  }

  .doctrine-hero-label {
    font-family: var(--ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: var(--space-md);
  }

  .doctrine-hero-title {
    font-family: var(--display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-md);
    color: var(--text);
  }

  .doctrine-hero-tagline {
    font-family: var(--display);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 400;
    font-style: italic;
    color: var(--muted);
    margin: 0 0 var(--space-md);
  }

  .doctrine-hero-desc {
    font-family: var(--body);
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--muted);
    margin: 0;
  }

  .doctrine-context {
    padding: 0 0 var(--space-3xl);
  }

  .doctrine-context-inner {
    max-width: var(--site-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-lg);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .doctrine-context-item {
    padding: 0;
  }

  .doctrine-context-label {
    font-family: var(--ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .doctrine-context-copy {
    font-family: var(--body);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }

  .doctrine-series {
    padding: var(--space-3xl) 0;
  }

  .doctrine-series-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .doctrine-series-label {
    font-family: var(--ui);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
  }

  .doctrine-series-count {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--subtle);
  }

  .doctrine-branches {
    padding: 0 0 var(--space-4xl);
  }

  .doctrine-branches-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .doctrine-branches-label {
    font-family: var(--ui);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
  }

  .doctrine-branch-group {
    margin-bottom: var(--space-3xl);
  }

  .doctrine-branch-group-title {
    font-family: var(--ui);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 var(--space-lg);
  }

  .series-card {
    position: relative;
    background: var(--bg-alt);
    padding: var(--space-xl);
    box-shadow:
      0 16px 32px -8px rgba(0,0,0,0.04),
      0 1px 2px rgba(0,0,0,0.04);
    border: 1px solid var(--border);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.5s ease-out calc(var(--i, 0) * 80ms),
      transform 0.4s var(--ease-heavy) calc(var(--i, 0) * 80ms);
  }

  .series-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .series-card:hover {
    transform: translateY(-6px);
  }

  .series-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 400ms var(--ease-heavy);
  }

  .series-card:hover::after {
    transform: scaleX(1);
  }

  .series-card-inner {
    position: relative;
    z-index: 1;
  }

  .series-card-number {
    font-family: var(--ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--subtle);
    margin-bottom: var(--space-sm);
    display: block;
  }

  .series-card-title {
    font-family: var(--display);
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-sm);
    color: var(--text);
    transition: color 100ms ease-out;
  }

  .series-card:hover .series-card-title {
    color: var(--accent);
  }

  .series-card-desc {
    margin: 0;
    font-family: var(--body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
  }
</style>
