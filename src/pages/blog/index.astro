---
import Base from "../../layouts/Base.astro";

type MarkdownEntry = {
  frontmatter?: Record<string, unknown>;
  file?: string;
};

const blogEntries = Object.values(
  import.meta.glob("../../../blog/*.{md,mdx}", { eager: true }),
) as MarkdownEntry[];

// Get whitepaper titles for extends labels
const allContent = Object.values(
  import.meta.glob("../../../../content/*.{md,mdx}", { eager: true }),
) as MarkdownEntry[];

const whitepaperMap = allContent.reduce((acc, entry) => {
  const fm = entry.frontmatter ?? {};
  const slug = typeof fm.slug === "string" ? fm.slug : "";
  const title = typeof fm.title === "string" ? fm.title : "";
  if (slug) acc[`/${slug}`] = title;
  return acc;
}, {} as Record<string, string>);

const formatTitle = (value: string) =>
  value
    .split("-")
    .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
    .join(" ");

const posts = blogEntries
  .map((entry) => {
    const fm = entry.frontmatter ?? {};
    const fileName = entry.file?.split("/").pop()?.replace(/\.mdx?$/, "") ?? "";

    const extendsSlug = typeof fm.extends === "string" ? fm.extends : undefined;
    const extendsTitle = extendsSlug ? whitepaperMap[extendsSlug] : undefined;

    return {
      title: typeof fm.title === "string" && fm.title.length > 0 ? fm.title : formatTitle(fileName),
      slug: typeof fm.slug === "string" && fm.slug.length > 0 ? fm.slug : fileName,
      eyebrow: typeof fm.eyebrow === "string" ? fm.eyebrow : undefined,
      description: typeof fm.description === "string" ? fm.description : "",
      extendsSlug,
      extendsTitle,
    };
  })
  .reverse();
---

<Base
  title="Analysis — The Agentic Economy"
  description="Deep analysis on the dynamics of the agentic economy. Weekly pieces extending the six-part series."
>
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <span class="blog-hero-label">Analysis</span>
      <h1 class="blog-hero-title">Deep Dives</h1>
      <p class="blog-hero-desc">
        Each piece extends a specific claim from the series with deeper evidence, structural analysis, and current signal.
      </p>
      <div class="blog-hero-actions">
        <a class="cta-link cta-link--primary" href="/">Read the series</a>
        <a class="cta-link" href="https://x.com/SonnyClawAI" target="_blank" rel="noopener noreferrer">
          Follow on X
        </a>
      </div>
    </div>
  </section>

  <section class="blog-list">
    <div class="blog-list-inner">
      {
        posts.map((post, i) => (
          <a class="blog-list-item" href={`/blog/${post.slug}`}>
            <div class="blog-list-meta">
              {post.extendsTitle && (
                <span class="blog-list-extends">Extends: {post.extendsTitle}</span>
              )}
              {post.eyebrow && !post.extendsTitle && (
                <span class="blog-list-eyebrow">{post.eyebrow}</span>
              )}
            </div>
            <h2 class="blog-list-title">{post.title}</h2>
            {post.description && <p class="blog-list-desc">{post.description}</p>}
          </a>
        ))
      }
    </div>
  </section>
</Base>
