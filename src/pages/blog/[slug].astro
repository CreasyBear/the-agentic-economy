---
import BlogPost from "../../layouts/BlogPost.astro";

type MarkdownEntry = {
  frontmatter?: Record<string, unknown>;
  file?: string;
  default: any;
};

type Meta = {
  title: string;
  slug: string;
  eyebrow?: string;
  description?: string;
  heroImage?: string;
  extends?: string;
  extendsDescription?: string;
  date?: string;
};

export async function getStaticPaths() {
  const formatTitle = (value: string) =>
    value
      .split("-")
      .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
      .join(" ");

  const normalizeEntry = (entry: MarkdownEntry): { entry: MarkdownEntry; meta: Meta } => {
    const fm = entry.frontmatter ?? {};
    const fileName = entry.file?.split("/").pop()?.replace(/\.mdx?$/, "") ?? "";

    return {
      entry,
      meta: {
        title: typeof fm.title === "string" && fm.title.length > 0 ? fm.title : formatTitle(fileName),
        slug: typeof fm.slug === "string" && fm.slug.length > 0 ? fm.slug : fileName,
        eyebrow: typeof fm.eyebrow === "string" ? fm.eyebrow : undefined,
        description: typeof fm.description === "string" ? fm.description : undefined,
        heroImage: typeof fm.heroImage === "string" ? fm.heroImage : undefined,
        extends: typeof fm.extends === "string" ? fm.extends : undefined,
        extendsDescription: typeof fm.exts_description === "string" ? fm.exts_description : undefined,
        date: typeof fm.date === "string" ? fm.date : undefined,
      },
    };
  };

  const blogEntries = Object.values(
    import.meta.glob("../../../blog/*.{md,mdx}", { eager: true }),
  ) as MarkdownEntry[];

  return blogEntries.map(normalizeEntry).map((item) => ({
    params: { slug: item.meta.slug },
    props: { entry: item.entry, meta: item.meta },
  }));
}

const { entry, meta } = Astro.props as { entry: MarkdownEntry; meta: Meta };
const Content = entry.default as any;
---

<BlogPost
  title={meta.title}
  eyebrow={meta.eyebrow}
  description={meta.description}
  heroImage={meta.heroImage}
  extends={meta.extends}
  extendsDescription={meta.extendsDescription}
  date={meta.date}
>
  <Content />
</BlogPost>
