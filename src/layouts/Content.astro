---
import Base from "./Base.astro";
import AuthorBio from "../components/AuthorBio.astro";

type ContentType = "doctrine" | "signal" | "reference";

type MarkdownEntry = {
  frontmatter?: Record<string, unknown>;
  file?: string;
};

// Doctrine series (for series footer + extends resolution)
const allContent = Object.values(
  import.meta.glob("../../content/*.{md,mdx}", { eager: true }),
) as MarkdownEntry[];

const seriesEntries = allContent
  .map((entry) => {
    const fm = entry.frontmatter ?? {};
    return {
      title: typeof fm.title === "string" ? fm.title : "",
      slug: typeof fm.slug === "string" ? fm.slug : "",
      order: typeof fm.order === "number" ? fm.order : 999,
    };
  })
  .sort((a, b) => a.order - b.order);

// Whitepaper map for extends resolution
const whitepaperMap = seriesEntries.reduce((acc, e) => {
  if (e.slug) acc[`/${e.slug}`] = e.title;
  return acc;
}, {} as Record<string, string>);

// Reference series (for ref footer)
const refPieces = [
  { slug: "pd-00-infrastructure-hits", title: "The Physical Toll", num: "00" },
  { slug: "pd-01-guarantor", title: "The Guarantor Became the Source", num: "01" },
  { slug: "pd-02-vault-drain", title: "The Vault Drain", num: "02" },
  { slug: "pd-03-yuan-strait", title: "Yuan at the Strait", num: "03" },
  { slug: "pd-04-hierarchy", title: "The Hierarchy Breaks From the Bottom", num: "04" },
  { slug: "pd-05-who-pays", title: "Who Pays", num: "05" },
  { slug: "pd-06-petrodollar-2", title: "Petrodollar 2.0", num: "06" },
  { slug: "pd-07-australias-moment", title: "Australia's Moment", num: "07" },
];

// Related signals: blog posts that extend this piece
type BlogEntry = {
  frontmatter?: Record<string, unknown>;
  file?: string;
};

const allBlog = Object.values(
  import.meta.glob("../../blog/*.{md,mdx}", { eager: true }),
) as BlogEntry[];

interface NavItem {
  slug: string;
  title: string;
}

interface Props {
  type?: ContentType;
  title: string;
  eyebrow?: string;
  description?: string;
  heroImage?: string;
  date?: string;
  extends?: string;
  extendsDescription?: string;
  prev?: NavItem | null;
  next?: NavItem | null;
}

const {
  type = "doctrine",
  title,
  eyebrow,
  description,
  heroImage,
  date = "2026-01-01",
  extends: extendsSlug,
  extendsDescription,
  prev = null,
  next = null,
} = Astro.props;

const currentSlug = Astro.url.pathname.replace(/^\//, "").replace(/\/$/, "");
const pageTitle = `${title} — The Agentic Economy`;
const shareImage = heroImage
  ? heroImage.replace("/images/", "/og/").replace(/\.webp$/, ".jpg")
  : "/og/agentic-economy-share.jpg";

const extendsTitle = extendsSlug ? whitepaperMap[extendsSlug] : undefined;

// Related signals
const relatedSignals = allBlog
  .map((entry) => {
    const fm = entry.frontmatter ?? {};
    return {
      title: typeof fm.title === "string" ? fm.title : "",
      slug: typeof fm.slug === "string" ? fm.slug : "",
      extends: typeof fm.extends === "string" ? fm.extends : "",
    };
  })
  .filter((post) => post.extends === `/${currentSlug}` && post.slug);

// Series navigation
const entryEssay = seriesEntries.find((e) => e.order === 0) ?? seriesEntries[0];
const isEntryEssay = currentSlug === entryEssay?.slug;
const isFinalEssay = next === null;

// Formatted date
const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric",
}).format(new Date(date));

// JSON-LD
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description ?? "",
  datePublished: date,
  dateModified: date,
  author: {
    "@type": "Person",
    name: "Sonny",
    url: "https://www.agentic-economy.ai",
    sameAs: ["https://x.com/SonnyClawAI"],
  },
  publisher: {
    "@type": "Organization",
    name: "The Agentic Economy",
    url: "https://www.agentic-economy.ai",
  },
  url: Astro.url.toString(),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: new URL("/", Astro.site).toString() },
    {
      "@type": "ListItem",
      position: 2,
      name: type === "signal" ? "Signals" : type === "reference" ? "Reference" : "Doctrine",
      item: new URL(
        type === "signal" ? "/signals" : type === "reference" ? "/ref" : "/doctrine",
        Astro.site,
      ).toString(),
    },
    { "@type": "ListItem", position: 3, name: title, item: Astro.url.toString() },
  ],
};

// Context links per type
const contextLinks = {
  doctrine: [
    { label: "Doctrine", href: "/doctrine" },
    { label: "Start the series", href: "/entry" },
  ],
  signal: [
    { label: "Doctrine", href: "/doctrine" },
    { label: "All signals", href: "/signals" },
    { label: "Start the series", href: "/entry" },
  ],
  reference: [
    { label: "Doctrine", href: "/doctrine" },
    { label: "Reference", href: "/ref" },
  ],
};

// CTA copy per type
const ctaCopy = {
  doctrine: {
    kicker: isFinalEssay ? "Series Complete" : "Continue The Inquiry",
    copy: isFinalEssay
      ? "The series is complete. We wrote the diagnosis — now we're building the infrastructure."
      : "Keep moving through the series, or follow the work as the argument develops in public.",
    primary: next ? { label: "Read the next essay", href: `/${next.slug}` } : { label: "See what we're building", href: "/handshake" },
    secondary: isFinalEssay
      ? { label: "Return to the series", href: "/" }
      : { label: "Follow on X", href: "https://x.com/SonnyClawAI", external: true },
  },
  signal: {
    kicker: "Signal",
    copy: extendsSlug && extendsTitle
      ? `This piece extends ${extendsTitle} with deeper evidence and structural analysis.`
      : "Rapid analysis of events as they unfold.",
    primary: { label: "All signals", href: "/signals" },
    secondary: { label: "Start the series", href: "/entry" },
  },
  reference: {
    kicker: "Reference",
    copy: extendsSlug && extendsTitle
      ? `Structured analysis connected to ${extendsTitle}.`
      : "Structured analysis and protocol maps.",
    primary: { label: "All reference", href: "/ref" },
    secondary: { label: "Start the series", href: "/entry" },
  },
};

const cta = ctaCopy[type];
---

<Base title={pageTitle} description={description} image={shareImage} ogType="article" publishedTime={date} modifiedTime={date}>
  <head>
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </head>

  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <article class="essay-shell" data-type={type}>
    {/* ── Meta: eyebrow · date ── */}
    {eyebrow && (
      <div class="essay-meta">
        <span class="essay-meta-label">{eyebrow}</span>
        <span class="essay-meta-sep" aria-hidden="true">·</span>
        <time datetime={date}>{formattedDate}</time>
      </div>
    )}

    {/* ── Title ── */}
    <h1 class="essay-title">{title}</h1>

    {/* ── Extends link (signals + reference) ── */}
    {extendsSlug && extendsTitle && (
      <div class="blog-extends">
        <span class="blog-extends-label">Extends</span>
        <a class="blog-extends-link" href={extendsSlug}>{extendsTitle}</a>
        {extendsDescription && <p class="blog-extends-desc">{extendsDescription}</p>}
      </div>
    )}

    {/* ── Standfirst ── */}
    {description && (
      <>
        <p class="essay-standfirst">{description}</p>
        <hr class="essay-standfirst-rule" aria-hidden="true" />
      </>
    )}

    {/* ── Context links ── */}
    <div class="essay-context-links" aria-label="Navigation">
      {contextLinks[type].map((link, i) => (
        <>
          {i > 0 && <span aria-hidden="true">·</span>}
          <a href={link.href}>{link.label}</a>
        </>
      ))}
    </div>

    {/* ── Hero image ── */}
    {heroImage && (
      <div class="essay-hero">
        <img
          src={heroImage}
          alt=""
          class="essay-hero-img"
          role="presentation"
          width="2400"
          height="1309"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    )}

    {/* ── Prose ── */}
    <div class={`essay-prose essay-prose--${type}`}>
      <slot />
    </div>

    {/* ── CTA ── */}
    <section class="essay-cta" aria-label="Continue">
      <p class="essay-cta-kicker">{cta.kicker}</p>
      <p class="essay-cta-copy">{cta.copy}</p>
      <div class="essay-cta-actions">
        <a
          class="cta-link cta-link--primary"
          href={cta.primary.href}
          data-track-event="cta_click"
          data-track-location={`${type}_footer`}
          data-track-target={cta.primary.href}
        >
          {cta.primary.label}
        </a>
        <a
          class="cta-link"
          href={cta.secondary.href}
          {...(cta.secondary.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          data-track-event="cta_click"
          data-track-location={`${type}_footer`}
          data-track-target={cta.secondary.href}
        >
          {cta.secondary.label}
        </a>
      </div>
    </section>

    {/* ── Prev/Next nav (doctrine + reference) ── */}
    {(type === "doctrine" || type === "reference") && (prev || next) && (
      <nav class="essay-nav" aria-label="Content navigation">
        {prev ? (
          <a class="essay-nav-link" href={`/${prev.slug}`}>← {prev.title}</a>
        ) : (
          <span class="essay-nav-link" aria-hidden="true"></span>
        )}
        <span class="essay-nav-spacer" aria-hidden="true"></span>
        {next ? (
          <a class="essay-nav-link" href={`/${next.slug}`}>{next.title} →</a>
        ) : (
          <span class="essay-nav-link" aria-hidden="true"></span>
        )}
      </nav>
    )}

    {/* ── Author bio ── */}
    <AuthorBio date={date} />

    {/* ── Related signals ── */}
    {relatedSignals.length > 0 && (
      <section class="essay-related" aria-label="Related signals">
        <h2 class="essay-related-heading">Related Signals</h2>
        <ul class="essay-related-list">
          {relatedSignals.map((signal) => (
            <li>
              <a href={`/blog/${signal.slug}`}>{signal.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* ── Footer: type-specific series list ── */}
    {type === "doctrine" && (
      <footer class="essay-footer">
        <p class="essay-footer-note">Part of <em>The Agentic Economy</em>.</p>
        <nav class="essay-series-list" aria-label="Series contents">
          {seriesEntries.map((entry) => (
            <a
              class={`essay-series-item${entry.slug === currentSlug ? " is-current" : ""}`}
              href={`/${entry.slug}`}
              aria-current={entry.slug === currentSlug ? "page" : undefined}
            >
              <span class="essay-series-item-num">{String(entry.order).padStart(2, "0")}</span>
              <span class="essay-series-item-title">{entry.title}</span>
            </a>
          ))}
        </nav>
      </footer>
    )}

    {type === "signal" && (
      <footer class="essay-footer">
        <p class="essay-footer-note">Part of <em>The Agentic Economy</em> — rapid analysis extending the core doctrine.</p>
      </footer>
    )}

    {type === "reference" && (
      <footer class="essay-footer">
        <p class="essay-footer-note">Part of the <em>Petrodollar Series</em> — structured analysis of the global monetary shift.</p>
        <nav class="essay-series-list" aria-label="Reference series">
          {refPieces.map((piece) => (
            <a
              class={`essay-series-item${piece.slug === currentSlug ? " is-current" : ""}`}
              href={`/ref/${piece.slug}`}
              aria-current={piece.slug === currentSlug ? "page" : undefined}
            >
              <span class="essay-series-item-num">{piece.num}</span>
              <span class="essay-series-item-title">{piece.title}</span>
            </a>
          ))}
        </nav>
      </footer>
    )}
  </article>

  <script>
    const bar = document.getElementById("reading-progress");
    if (bar) {
      let rafId: ReturnType<typeof requestAnimationFrame> | null = null;
      const update = () => {
        const scrolled = window.scrollY;
        const total = Math.max(document.body.scrollHeight - window.innerHeight, 1);
        const pct = Math.min(scrolled / total, 1) * 100;
        bar.style.width = `${pct}%`;
        rafId = null;
      };
      window.addEventListener(
        "scroll",
        () => { if (rafId === null) rafId = requestAnimationFrame(update); },
        { passive: true },
      );
      update();
    }
  </script>
</Base>
