---
import Base from "./Base.astro";

type MarkdownEntry = {
  frontmatter?: Record<string, unknown>;
  file?: string;
};

// Find the whitepaper this extends
const allContent = Object.values(
  import.meta.glob("../../content/*.{md,mdx}", { eager: true }),
) as MarkdownEntry[];

const whitepaperMap = allContent.reduce((acc, entry) => {
  const fm = entry.frontmatter ?? {};
  const slug = typeof fm.slug === "string" ? fm.slug : "";
  const title = typeof fm.title === "string" ? fm.title : "";
  if (slug) acc[`/${slug}`] = title;
  return acc;
}, {} as Record<string, string>);

interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
  heroImage?: string;
  extends?: string;
  extendsDescription?: string;
  date?: string;
}

const { title, eyebrow, description, heroImage, extends: extendsSlug, extendsDescription, date = "2026-03-28" } = Astro.props;

const pageTitle = `${title} — The Agentic Economy`;
const shareImage = heroImage
  ? heroImage.replace("/images/", "/og/").replace(/\.webp$/, ".jpg")
  : "/og/agentic-economy-share.jpg";

const extendsTitle = extendsSlug ? whitepaperMap[extendsSlug] : undefined;

// JSON-LD: Article
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description ?? "",
  "datePublished": date,
  "dateModified": date,
  "author": {
    "@type": "Organization",
    "name": "The Agentic Economy team"
  },
  "url": Astro.url.toString(),
  "isPartOf": {
    "@type": "Blog",
    "name": "The Agentic Economy"
  }
};

// JSON-LD: Breadcrumb
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": new URL("/", Astro.site).toString()
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": new URL("/blog", Astro.site).toString()
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": Astro.url.toString()
    }
  ]
};
---

<Base title={pageTitle} description={description} image={shareImage} ogType="article" publishedTime={date} modifiedTime={date}>
  <head>
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </head>

  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <article class="essay-shell">
    {eyebrow && (
      <div class="essay-meta">
        <span class="essay-meta-label">{eyebrow}</span>
        <span class="essay-meta-sep" aria-hidden="true">·</span>
        <span>{new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' }).format(new Date(date ?? '2026-01-01'))}</span>
      </div>
    )}
    <h1 class="essay-title">{title}</h1>

    {extendsSlug && extendsTitle && (
      <div class="blog-extends">
        <span class="blog-extends-label">Extends</span>
        <a class="blog-extends-link" href={extendsSlug}>
          {extendsTitle}
        </a>
        {extendsDescription && (
          <p class="blog-extends-desc">{extendsDescription}</p>
        )}
      </div>
    )}

    {description && (
      <>
        <p class="essay-standfirst">{description}</p>
        <hr class="essay-standfirst-rule" aria-hidden="true" />
      </>
    )}

    <div class="essay-context-links" aria-label="Navigation">
      <a href="/">Series overview</a>
      <span aria-hidden="true">·</span>
      <a href="/blog">All analysis</a>
      <span aria-hidden="true">·</span>
      <a href="/entry">Start the series</a>
    </div>

    {heroImage && (
      <div class="essay-hero">
        <img
          src={heroImage}
          alt=""
          class="essay-hero-img"
          role="presentation"
          width="2400"
          height="1309"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    )}

    <div class="essay-prose">
      <slot />
    </div>

    <section class="essay-cta" aria-label="Continue">
      <p class="essay-cta-kicker">Deep Dive</p>
      <p class="essay-cta-copy">
        This piece extends a specific claim from the series with deeper evidence and structural analysis.
        {extendsSlug && extendsTitle && (
          <> Read <a href={extendsSlug}>{extendsTitle}</a> for the full framework.</>
        )}
      </p>
      <div class="essay-cta-actions">
        <a
          class="cta-link cta-link--primary"
          href="/blog"
          data-track-event="cta_click"
          data-track-location="blog_footer"
          data-track-target="blog_index"
        >
          All analysis
        </a>
        <a
          class="cta-link"
          href="/entry"
          data-track-event="cta_click"
          data-track-location="blog_footer"
          data-track-target="series_entry"
        >
          Start the series
        </a>
      </div>
    </section>

    <footer class="essay-footer">
      <p class="essay-footer-note">
        Part of <em>The Agentic Economy</em> — Deep analysis extending the core doctrine.
      </p>
    </footer>
  </article>

  <script>
    const bar = document.getElementById("reading-progress");
    if (bar) {
      let rafId: ReturnType<typeof requestAnimationFrame> | null = null;
      const update = () => {
        const scrolled = window.scrollY;
        const total = Math.max(document.body.scrollHeight - window.innerHeight, 1);
        const pct = Math.min(scrolled / total, 1) * 100;
        bar.style.width = `${pct}%`;
        rafId = null;
      };
      window.addEventListener(
        "scroll",
        () => { if (rafId === null) rafId = requestAnimationFrame(update); },
        { passive: true },
      );
      update();
    }
  </script>
</Base>
