---
import GulfDamageMap from './GulfDamageMap';
---
<div class="gulf-map-container" style="position:relative;min-height:60vh;border-radius:12px;overflow:hidden;border:1px solid #27272a;background:#09090b;">
  <div class="gulf-map-loading" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:#a1a1aa;font-family:system-ui,sans-serif;">
    <div style="display:flex;gap:16px;">
      <div style="text-align:center;"><div style="font-size:28px;font-weight:800;color:#fff;">41</div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;">Assets Hit</div></div>
      <div style="text-align:center;"><div style="font-size:28px;font-weight:800;color:#dc2626;">3</div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;">Destroyed</div></div>
      <div style="text-align:center;"><div style="font-size:28px;font-weight:800;color:#f59e0b;">31</div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;">Damaged</div></div>
      <div style="text-align:center;"><div style="font-size:28px;font-weight:800;color:#6366f1;">7</div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;">Threatened</div></div>
    </div>
    <div style="font-size:13px;">Loading interactive map...</div>
  </div>
  <GulfDamageMap client:only="react" />
</div>

<style>
  .gulf-map-container .gulf-map-wrapper {
    position: absolute;
    inset: 0;
  }
  .gulf-map-container .gulf-map-wrapper:has(.maplibregl-map) ~ .gulf-map-loading {
    display: none;
  }
</style>
